{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user profile with role and contact info",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "project_manager", "team_member", "viewer"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "photoURL": { "type": "string", "format": "uri" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "Enterprise project details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "client": { "type": "string" },
        "description": { "type": "string" },
        "managerId": { "type": "string", "description": "User ID of the project manager" },
        "startDate": { "type": "string", "format": "date-time" },
        "deadline": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "completed", "archived", "delayed"] },
        "budget": { "type": "number" },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "progress": { "type": "number", "description": "Percentage 0-100" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "managerId", "status", "deadline", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "Specific task within a project",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedTo": { "type": "string", "description": "User ID of the assignee" },
        "startDate": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "review", "completed", "overdue"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "progress": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "title", "assignedTo", "status", "dueDate", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notification for users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["task_assignment", "deadline_approaching", "overdue", "status_change"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "relatedEntityId": { "type": "string", "description": "ID of the project or task" }
      },
      "required": ["userId", "message", "type", "read", "createdAt"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "Audit log for system actions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "entityType": { "type": "string", "enum": ["project", "task", "user"] },
        "entityId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "string" }
      },
      "required": ["userId", "action", "entityType", "entityId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/projects/{projectId}": { "schema": "Project", "description": "Projects" },
    "/tasks/{taskId}": { "schema": "Task", "description": "Tasks" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" },
    "/activityLogs/{logId}": { "schema": "ActivityLog", "description": "System activity logs" }
  }
}
